{
  "name": "@crucible-agr/agent-openrouter",
  "version": "0.1.0",
  "description": "OpenRouter/AI SDK ReAct agent adapter for the Crucible framework",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --treeshake",
    "build:watch": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.1.0",
    "@crucible-agr/core": "workspace:*",
    "ai": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "@crucible-agr/core": "^0.1.0"
  }
}
