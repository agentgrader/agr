{
  "name": "@agentgrader/core",
  "version": "1.0.1",
  "description": "Core schemas, contracts, and runner for the Agentgrader benchmarking framework",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --treeshake",
    "build:watch": "tsup src/index.ts --format esm --dts --watch",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "@agentgrader/store": "^1.0.1",
    "@mastra/core": "^1.41.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
