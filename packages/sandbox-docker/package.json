{
  "name": "@crucible-agr/sandbox-docker",
  "version": "0.1.0",
  "description": "Docker-based SandboxProvider implementation for the Crucible framework",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --treeshake",
    "build:watch": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@crucible-agr/core": "workspace:*",
    "dockerode": "^4.0.2"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "@crucible-agr/core": "^0.1.0"
  }
}
