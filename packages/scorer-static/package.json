{
  "name": "@agentgrader/scorer-static",
  "version": "3.0.0",
  "description": "Deterministic code-quality scorer (diff size, TODOs, lint) for Agentgrader",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --treeshake",
    "build:watch": "tsup src/index.ts --format esm --dts --watch",
    "test": "bun test src"
  },
  "dependencies": {
    "@agentgrader/core": "^1.4.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "@agentgrader/core": "^1.4.0"
  }
}
